# next-auth
AUTH_SECRET=replace-with-output-of-pnpm-dlx-auth-secret
AUTH_TRUST_HOST=true

# Login admin (single-user MVP)
ADMIN_EMAIL=gustavo.azvd@gmail.com
ADMIN_PASSWORD=replace-with-strong-password

# Postgres do worker Semente. Em prod: internal_db_url do Coolify
# (postgres://worker:<senha>@<uuid>:5432/worker). Em dev local: setar
# USE_MOCK_STATS=true e deixar DATABASE_URL vazio (banco não exposto).
DATABASE_URL=
USE_MOCK_STATS=true

# GitHub PAT com escopo contents:read+write nos repos dos agentes.
# Console usa pra clonar e commitar mudanças de PROJECT.md.
GITHUB_TOKEN=

# Coolify API — usada pra disparar redeploy desta própria app
# após salvar mudanças em agents.yml (modelos por tier, etc.).
# Sem isso, só commitamos e esperamos webhook do GitHub.
COOLIFY_API_URL=http://5.78.199.192:8000/api/v1
COOLIFY_API_TOKEN=
COOLIFY_APP_UUID=kkmzz43bx8y2u8r9scmghp30

# Evolution API (WhatsApp gateway) — usado pra gerar QR e reconectar instâncias
EVOLUTION_API_URL=https://evolution.beeads.com.br
EVOLUTION_API_KEY=
